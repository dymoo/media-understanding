{
  "name": "@dymoo/media-understanding",
  "version": "0.1.3",
  "description": "MCP server that converts audio/video/image to text + images for LLM consumption",
  "type": "module",
  "license": "MIT",
  "author": "dymoo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dymoo/media-understanding.git"
  },
  "keywords": [
    "mcp",
    "llm",
    "media",
    "video",
    "audio",
    "transcription",
    "parakeet",
    "onnx",
    "ffmpeg",
    "opencode",
    "agents"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "media-understanding": "dist/cli.js",
    "media-understanding-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "bench:parakeet:cpu": "node scripts/benchmark-ep.mjs --json",
    "bench:parakeet:mlx": "tmp/benchmarks/.venv/bin/python scripts/benchmark-parakeet-mlx.py",
    "bench:whisper:cpp": "node scripts/benchmark-whisper-cpp.mjs",
    "bench:asr:matrix": "node scripts/benchmark-asr-matrix.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "check-all": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "postinstall": "node scripts/install-node-av.mjs && node scripts/download-parakeet-model.mjs",
    "test": "node --test dist/tests/*.test.js",
    "pretest": "tsc",
    "prepublishOnly": "pnpm run check-all && pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "file-type": "^21.3.1",
    "node-av": "^5.2.2",
    "onnxruntime-node": "^1.24.3",
    "sharp": "^0.34.5",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@seydx/node-av-darwin-arm64": "^5.2.2",
    "@seydx/node-av-darwin-x64": "^5.2.2",
    "@seydx/node-av-linux-arm64": "^5.2.2",
    "@seydx/node-av-linux-x64": "^5.2.2",
    "@seydx/node-av-win32-arm64-mingw": "^5.2.2",
    "@seydx/node-av-win32-arm64-msvc": "^5.2.2",
    "@seydx/node-av-win32-x64-mingw": "^5.2.2",
    "@seydx/node-av-win32-x64-msvc": "^5.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.32.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
